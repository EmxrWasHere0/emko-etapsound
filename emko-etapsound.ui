<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name emko-etapsound.ui -->
  <requires lib="gtk" version="4.6"/>
  <object class="GtkWindow" id="pencere">
    <property name="child">
      <object class="GtkBox" id="kutucuk">
        <property name="homogeneous">True</property>
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkLabel" id="baslik">
            <property name="css-name">label2</property>
            <property name="label">&lt;span size="xx-large"&gt;Emko-EtapSound'a Hoş Geldiniz!&lt;/span&gt;</property>
            <property name="use-markup">True</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="aciklama">
            <property name="justify">center</property>
            <property name="label">&lt;span weight='bold'&gt;Bu sihirbaz, Pardus sisteminizdeki ses kütüphanelerini düzeltecektir.
İnternet bağlantısı ve sertifikanın imzalı olması gerekmektedir.
Devam etmek için 'Devam' tuşuna basınız.&lt;/span&gt;</property>
            <property name="use-markup">True</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="buton">
            <property name="label">Devam</property>
          </object>
        </child>
      </object>
    </property>
    <property name="default-height">300</property>
    <property name="default-width">400</property>
    <property name="resizable">False</property>
    <property name="title">Emko-EtapSound</property>
  </object>
</interface>
